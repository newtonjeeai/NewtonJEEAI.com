APP_NAME="NewtonJEE"
APP_URL=https://newtonjee.com
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Asia/Kolkata

# Database — AWS RDS ap-south-1
DB_HOST=your-rds-endpoint.ap-south-1.rds.amazonaws.com
DB_PORT=3306
DB_NAME=newtonjee
DB_USER=newtonjee_user
DB_PASS=your_secure_password

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://newtonjee.com/auth/google/callback

# Email (SMTP) — notifications only, not used for login
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_FROM=no-reply@newtonjee.com
SMTP_FROM_NAME="NewtonJEE"

# Session
SESSION_LIFETIME=28800
SESSION_NAME=nj_session

# File uploads
UPLOAD_MAX_SIZE=52428800
NOTEBOOK_UPLOAD_PATH=/var/www/private/notebooks
NOTEBOOK_MAX_SIZE=26214400

# Mentor shared Google account for notebook submissions
MENTOR_DRIVE_EMAIL=mentor@newtonjee.com
